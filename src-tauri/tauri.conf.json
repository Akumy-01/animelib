{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "animelib",
  "version": "0.1.3",
  "identifier": "com.anishelf.windows",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost https://api.themoviedb.org https://api.tmdb.org; img-src 'self' https://image.tmdb.org data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    },
    "windows": [
      {
        "title": "animelib",
        "width": 1180,
        "height": 780,
        "minWidth": 900,
        "minHeight": 620
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}
